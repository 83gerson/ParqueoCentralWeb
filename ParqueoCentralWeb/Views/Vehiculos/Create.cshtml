@model ParqueoCentralWeb.Models.Vehiculo
@{
    ViewBag.Title = "Registrar vehículo";
}
<h2>Registrar vehículo</h2>
@using (Html.BeginForm("Create", "Vehiculos", FormMethod.Post, new { id = "frmVehiculo" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="mb-3">
        @Html.LabelFor(m => m.Placa, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Placa, new { @class = "form-control", id = "txtPlaca", autocomplete = "off" })
        @Html.ValidationMessageFor(m => m.Placa, "", new { @class = "text-danger" })
        <div id="mensajePlaca" class="form-text"></div>
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.TipoVehiculo, new { @class = "form-label" })
        @Html.EnumDropDownListFor(m => m.TipoVehiculo, "Seleccione un tipo", new { @class = "form-select" })
        @Html.ValidationMessageFor(m => m.TipoVehiculo, "", new { @class = "text-danger" })
    </div>


    <div class="mb-3">
        @Html.LabelFor(m => m.Propietario, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Propietario, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Propietario, "", new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Contacto, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Contacto, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
}

@section Scripts {
    <script src="~/Scripts/vehiculos.js"></script>
}
