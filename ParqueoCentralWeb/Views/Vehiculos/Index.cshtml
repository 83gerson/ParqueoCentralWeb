@model System.Collections.Generic.List<ParqueoCentralWeb.Models.Vehiculo>
@{
    ViewBag.Title = "Vehículos registrados";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Vehículos registrados</h2>
    <a class="btn btn-success" href="@Url.Action("Create")">+ Registrar vehículo</a>
</div>

<div class="mb-3">
    <input type="text" id="txtFiltroPlaca" class="form-control" placeholder="Buscar por placa..." value="@ViewBag.FiltroPlaca" autocomplete="off" />
</div>

<div id="contenedorTablaVehiculos">
    @Html.Partial("_TablaVehiculos", Model)
</div>

@section Scripts {
    <script src="~/Scripts/vehiculos.js"></script>
}
