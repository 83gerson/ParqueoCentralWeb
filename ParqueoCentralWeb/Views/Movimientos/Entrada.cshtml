@{
    ViewBag.Title = "Registrar entrada de vehículo";
}
<h2>Registrar entrada de vehículo</h2>

@Html.ValidationSummary(false, "", new { @class = "text-danger" })

@using (Html.BeginForm("Entrada", "Movimientos", FormMethod.Post, new { id = "frmEntrada" }))
{
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Placa del vehículo</label>
        <input type="text" name="placa" id="txtPlacaEntrada" class="form-control" required="required" autocomplete="off" value="@ViewBag.PlacaIngresada" />
        <div id="infoVehiculo" class="form-text"></div>
    </div>

    <div id="panelVehiculoNuevo" class="border rounded p-3 mb-3" style="display:none;">
        <h6>El vehículo no está registrado. Complete los siguientes datos:</h6>
        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label">Tipo de vehículo</label>
                <select name="tipoVehiculoNuevo" class="form-select">
                    <option value="Automovil">Automóvil</option>
                    <option value="Motocicleta">Motocicleta</option>
                    <option value="Buseta">Buseta</option>
                    <option value="Otro">Otro</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Propietario / conductor</label>
                <input type="text" name="propietarioNuevo" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Contacto (opcional)</label>
                <input type="text" name="contactoNuevo" class="form-control" />
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Espacio disponible</label>
        <select name="idEspacio" id="ddlEspacios" class="form-select" required="required"></select>
        <div class="form-text">La lista se actualiza automáticamente según los espacios disponibles (AJAX).</div>
    </div>

    <button type="submit" class="btn btn-primary">Registrar entrada</button>
    <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Cancelar</a>
}

@section Scripts {
    <script src="~/Scripts/movimientos.js"></script>
}
