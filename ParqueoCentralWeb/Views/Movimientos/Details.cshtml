@model ParqueoCentralWeb.Models.MovimientoEstacionamiento
@{
    ViewBag.Title = "Detalle de movimiento";
}
<h2>Detalle de movimiento</h2>
<div class="card">
    <div class="card-body">
        <p><strong>Placa:</strong> @Model.Vehiculo.Placa</p>
        <p><strong>Tipo de vehículo:</strong> @Model.Vehiculo.TipoVehiculo</p>
        <p><strong>Propietario:</strong> @Model.Vehiculo.Propietario</p>
        <p><strong>Espacio:</strong> @Model.Espacio.CodigoEspacio (@Model.Espacio.TipoEspacio)</p>
        <p><strong>Fecha/hora de entrada:</strong> @Model.FechaHoraEntrada.ToString("dd/MM/yyyy HH:mm:ss")</p>
        <p>
            <strong>Fecha/hora de salida:</strong>
            @(Model.FechaHoraSalida.HasValue ? Model.FechaHoraSalida.Value.ToString("dd/MM/yyyy HH:mm:ss") : "Aún no registrada (movimiento activo)")
        </p>
        <p><strong>Estado:</strong> @Model.EstadoMovimiento</p>
        <p><strong>Monto cobrado:</strong> @(Model.MontoCobrado.HasValue ? "₡" + Model.MontoCobrado.Value.ToString("N2") : "-")</p>
        <p><strong>Registrado por:</strong> @Model.UsuarioRegistro</p>
    </div>
</div>
<a href="@Url.Action("Index")" class="btn btn-secondary mt-3">Volver al historial</a>
